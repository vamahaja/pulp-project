# Environment variables for Pulp deployment

# Pulp Namespace
PULP_NAMESPACE="<your-pulp-namespace>"

# Pulp Replicas
API_REPLICAS="<your-api-replicas>"
CONTENT_REPLICAS="<your-content-replicas>"
WORKER_REPLICAS="<your-worker-replicas>"

# Route Host
ROUTE_HOST="<your-route-host>"

# Storage Classes
POSTGRES_STORAGE_CLASS="<your-postgres-storage-class>"
FILE_STORAGE_STORAGE_CLASS="<your-file-storage-storage-class>"
REDIS_STORAGE_CLASS="<your-redis-storage-class>"

# Storage Sizes
DB_STORAGE="<your-db-storage-size>Gi"
FILE_STORAGE="<your-file-storage-size>Gi"

# Secrets
REDIS_PASSWORD="<your-redis-password>"
PULP_ADMIN_PASSWORD="<your-pulp-admin-password>"
POSTGRES_PASSWORD="<your-postgres-credentials>"
